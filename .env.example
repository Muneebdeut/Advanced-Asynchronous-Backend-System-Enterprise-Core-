# ============================================================
# Project Core-Auth — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/coreauth_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Secrets (use separate, strong random strings) ---
ACCESS_TOKEN_SECRET=CHANGE_ME_ACCESS_SECRET_32_CHARS_MIN
REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_SECRET_32_CHARS_MIN

# --- Token Lifespans ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
APP_ENV=development
AUTO_CREATE_TABLES=true
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000
